---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Melanie Osborne">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-gray-900 mb-3">Let's Connect</h1>
    <p class="text-gray-500 mb-12 leading-relaxed">
      Whether you have a project in mind or just want to say hello, I'd love to hear from you.
    </p>

    <div class="space-y-6">
      <div class="flex items-center gap-5 p-5 rounded-2xl border border-gray-100 hover:border-gray-200 transition-colors">
        <div class="w-10 h-10 bg-accent-50 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium mb-0.5">Email</p>
          <a href="mailto:hello@melanieosborne.com" class="text-gray-800 font-medium hover:text-accent-600 transition-colors">
            hello@melanieosborne.com
          </a>
        </div>
      </div>

      <div class="flex items-center gap-5 p-5 rounded-2xl border border-gray-100 hover:border-gray-200 transition-colors">
        <div class="w-10 h-10 bg-accent-50 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-accent-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium mb-0.5">LinkedIn</p>
          <a href="https://linkedin.com/in/melanieosborne" target="_blank" rel="noopener noreferrer" class="text-gray-800 font-medium hover:text-accent-600 transition-colors">
            linkedin.com/in/melanieosborne
          </a>
        </div>
      </div>

      <div class="flex items-center gap-5 p-5 rounded-2xl border border-gray-100 hover:border-gray-200 transition-colors">
        <div class="w-10 h-10 bg-accent-50 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium mb-0.5">Currently</p>
          <p class="text-gray-800 font-medium">Open to opportunities</p>
        </div>
      </div>
    </div>
  </section>
</Base>
