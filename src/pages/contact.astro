---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Melanie Osborne">
  <section class="bg-accent-200 py-20 flex-1">
    <div class="max-w-2xl mx-auto px-6">
      <h1 class="text-4xl font-serif font-semibold text-gray-900 mb-3">
        <span class="bullet-mark"></span>Let's Connect
      </h1>
      <p class="text-gray-700 mb-12 leading-relaxed">
        Whether you have a project in mind or just want to say hello, I'd love to hear from you.
      </p>

      <div class="space-y-5">
        <div class="flex items-center gap-5 p-6 rounded-2xl bg-cream shadow-md">
          <div class="w-11 h-11 bg-teal-600/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-teal-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium mb-0.5">Email</p>
            <a href="mailto:hello@melanieosborne.com" class="text-gray-900 font-medium hover:text-teal-700 transition-colors">
              hello@melanieosborne.com
            </a>
          </div>
        </div>

        <div class="flex items-center gap-5 p-6 rounded-2xl bg-cream shadow-md">
          <div class="w-11 h-11 bg-teal-600/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-teal-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium mb-0.5">LinkedIn</p>
            <a href="https://linkedin.com/in/melanieosborne" target="_blank" rel="noopener noreferrer" class="text-gray-900 font-medium hover:text-teal-700 transition-colors">
              linkedin.com/in/melanieosborne
            </a>
          </div>
        </div>

        <div class="flex items-center gap-5 p-6 rounded-2xl bg-cream shadow-md">
          <div class="w-11 h-11 bg-teal-600/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-teal-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.148 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium mb-0.5">Instagram</p>
            <a href="https://instagram.com/melanieosbornedesigns" target="_blank" rel="noopener noreferrer" class="text-gray-900 font-medium hover:text-teal-700 transition-colors">
              @melanieosbornedesigns
            </a>
          </div>
        </div>

        <div class="flex items-center gap-5 p-6 rounded-2xl bg-cream shadow-md">
          <div class="w-11 h-11 bg-teal-600/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-teal-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium mb-0.5">Currently</p>
            <p class="text-gray-900 font-medium">Open to opportunities</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
