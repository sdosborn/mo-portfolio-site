---
import Base from '../layouts/Base.astro';
---

<Base title="About">
  <!-- Hero -->
  <section class="relative overflow-hidden flex-1 flex flex-col">
    <div class="absolute inset-0 grid grid-cols-1 md:grid-cols-[33%_67%]">
      <div class="bg-[#A4B5F7]"></div>
      <div class="bg-[#D9E2FB]"></div>
    </div>

    <div class="relative flex-1 flex items-center max-w-5xl mx-auto px-6 py-20">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <!-- Profile + name card -->
        <div class="shrink-0 bg-[#F5ECE6] rounded-3xl shadow-xl p-6 flex flex-col items-center gap-6">
          <div class="relative w-52 h-52 md:w-60 md:h-60 rounded-full overflow-hidden ring-4 ring-white shadow-xl bg-gradient-to-br from-accent-400 to-teal-600 flex items-center justify-center">
            <span class="font-serif text-4xl text-white/90">MO</span>
            <img
              src="/images/melanie.jpg"
              alt="Melanie Osborne"
              class="absolute inset-0 w-full h-full object-cover"
              onerror="this.remove()"
            />
          </div>
          <div class="px-8 py-6 text-center w-full max-w-xs">
            <h2 class="font-serif font-semibold text-xl text-gray-900">Melanie Osborne</h2>
            <div class="w-10 h-px bg-teal-600 mx-auto my-3"></div>
            <p class="text-xs tracking-[0.2em] uppercase text-gray-500 mb-4">UX Designer</p>
            <div class="flex items-center justify-center gap-4">
              <a href="https://linkedin.com/in/melanieosborne" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gray-600 hover:text-teal-600 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a href="https://instagram.com/melanieosbornedesigns" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-gray-600 hover:text-teal-600 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.148 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Headline -->
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-6xl md:text-7xl font-serif font-bold text-gray-900 leading-tight mb-6">
            Hi, I'm Melanie.
          </h1>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href="/projects" class="bg-gray-900 text-white px-6 py-3 rounded-full font-medium hover:bg-black transition-colors">
              View Portfolio
            </a>
            <a href="/contact" class="bg-white text-gray-900 px-6 py-3 rounded-full font-medium border border-gray-200 hover:border-gray-400 transition-colors">
              Contact Me
            </a>
          </div>
          <p class="mt-9 text-lg text-gray-700 leading-relaxed max-w-lg mx-auto md:mx-0">
            Welcome to my UX design portfolio! I'm a UX designer with a background in
            screenwriting and content development. I combine storytelling, empathy, and
            user-centered design to create accessible, inclusive, and intuitive digital
            experiences that solve real user needs. I believe that great experiences begin
            with understanding people.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
