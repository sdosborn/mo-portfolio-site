---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const featuredProjects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="About">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <div class="shrink-0">
        <div class="w-48 h-48 md:w-56 md:h-56 rounded-2xl bg-gray-100 overflow-hidden">
          <!-- Replace src with actual photo path once provided -->
          <img
            src={`${import.meta.env.BASE_URL}images/melanie.jpg`}
            alt="Melanie Osborne"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
        </div>
      </div>
      <div class="flex-1 text-center md:text-left">
        <p class="text-accent-600 font-medium text-sm tracking-widest uppercase mb-3">UX Designer</p>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-5">
          Hi, I'm Melanie.
        </h1>
        <p class="text-lg text-gray-500 leading-relaxed max-w-lg">
          I design digital experiences that are intuitive, thoughtful, and human-centered.
          Based in [City] — open to full-time and freelance work.
        </p>
        <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
          <a href={`${import.meta.env.BASE_URL}projects`} class="bg-accent-600 text-white px-6 py-3 rounded-full font-medium hover:bg-accent-700 transition-colors">
            View My Work
          </a>
          <a href={`${import.meta.env.BASE_URL}resume`} class="border border-gray-200 text-gray-700 px-6 py-3 rounded-full font-medium hover:border-gray-400 transition-colors">
            See Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="bg-gray-50 py-16">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-10">Featured Work</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {featuredProjects.map(project => (
            <a
              href={`${import.meta.env.BASE_URL}projects/${project.slug}`}
              class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-md transition-shadow"
            >
              <div class="aspect-video bg-gray-100" />
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.data.tags.map(tag => (
                    <span class="text-xs font-medium text-accent-600 bg-accent-50 px-2 py-1 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-accent-600 transition-colors mb-2">
                  {project.data.title}
                </h3>
                <p class="text-sm text-gray-500 leading-relaxed">{project.data.description}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={`${import.meta.env.BASE_URL}projects`} class="text-sm font-medium text-accent-600 hover:underline">
            View all projects →
          </a>
        </div>
      </div>
    </section>
  )}
</Base>
