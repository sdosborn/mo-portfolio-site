---
import Base from '../layouts/Base.astro';
---

<Base title="Resume" description="Resume of Melanie Osborne, UX Designer">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="flex items-start justify-between mb-12">
      <div>
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Resume</h1>
        <p class="text-gray-500">UX Designer</p>
      </div>
      <a
        href="/resume.pdf"
        download
        class="shrink-0 border border-gray-200 text-gray-700 px-5 py-2.5 rounded-full text-sm font-medium hover:border-gray-400 transition-colors"
      >
        Download PDF
      </a>
    </div>

    <!-- Experience -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-6">Experience</h2>
      <div class="space-y-8">
        <div class="flex gap-6">
          <div class="w-24 shrink-0 text-sm text-gray-400 pt-0.5">2022 – Present</div>
          <div>
            <h3 class="font-semibold text-gray-900">Senior UX Designer</h3>
            <p class="text-sm text-accent-600 mb-2">Company Name</p>
            <p class="text-sm text-gray-500 leading-relaxed">
              Led end-to-end UX design for [product/feature]. Placeholder — replace with actual experience.
            </p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="w-24 shrink-0 text-sm text-gray-400 pt-0.5">2019 – 2022</div>
          <div>
            <h3 class="font-semibold text-gray-900">UX Designer</h3>
            <p class="text-sm text-accent-600 mb-2">Company Name</p>
            <p class="text-sm text-gray-500 leading-relaxed">
              Placeholder — replace with actual experience.
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr class="border-gray-100 mb-12" />

    <!-- Education -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-6">Education</h2>
      <div class="flex gap-6">
        <div class="w-24 shrink-0 text-sm text-gray-400 pt-0.5">2015 – 2019</div>
        <div>
          <h3 class="font-semibold text-gray-900">B.S. / B.A. in [Field]</h3>
          <p class="text-sm text-accent-600">University Name</p>
        </div>
      </div>
    </section>

    <hr class="border-gray-100 mb-12" />

    <!-- Skills -->
    <section>
      <h2 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-6">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {[
          'User Research', 'Wireframing', 'Prototyping', 'Usability Testing',
          'Figma', 'Design Systems', 'Information Architecture', 'Interaction Design',
        ].map(skill => (
          <span class="text-sm text-gray-600 bg-gray-100 px-3 py-1.5 rounded-full">
            {skill}
          </span>
        ))}
      </div>
    </section>
  </section>
</Base>
