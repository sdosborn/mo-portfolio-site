---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Melanie Osborne Designs — UX Designer' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const socials = {
  linkedin: 'https://linkedin.com/in/melanieosborne',
  instagram: 'https://instagram.com/melanieosbornedesigns',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} — Melanie Osborne Designs</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <nav class="w-full px-8 md:px-16 h-24 flex items-center justify-between">
        <a href="/" class="flex items-center font-serif font-semibold text-gray-900 tracking-tight hover:text-accent-600 transition-colors">
          <span class="bullet-mark"></span>
          Melanie Osborne
          <span class="mx-2 text-gray-300 font-sans font-light">/</span>
          <span class="text-sm text-gray-500 font-sans font-normal">UX Designer</span>
        </a>
        <ul class="flex items-center gap-8 text-sm font-medium text-gray-500">
          <li><a href="/" class="hover:text-gray-900 transition-colors">About</a></li>
          <li><a href="/projects" class="hover:text-gray-900 transition-colors">Portfolio</a></li>
          <li><a href="/resume" class="hover:text-gray-900 transition-colors">Resume</a></li>
          <li>
            <a href="/contact" class="bg-teal-600 text-white px-4 py-2 rounded-full hover:bg-teal-700 transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer class="bg-white/95 border-t border-gray-100">
      <div class="w-full px-8 md:px-16 h-24 flex items-center justify-between gap-8">
        <span class="text-sm text-gray-600">© {new Date().getFullYear()} Melanie Osborne</span>
        <div class="flex items-center gap-12 text-center">
          <div>
            <p class="text-xs tracking-widest uppercase text-gray-500 mb-1">Write</p>
            <a href="mailto:hello@melanieosborne.com" class="text-sm font-medium text-gray-800 hover:text-teal-700 transition-colors">
              hello@melanieosborne.com
            </a>
          </div>
          <div>
            <p class="text-xs tracking-widest uppercase text-gray-500 mb-1">Follow</p>
            <div class="flex items-center justify-center gap-3">
              <a
                href={socials.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="w-9 h-9 flex items-center justify-center rounded-full bg-white text-gray-700 hover:bg-teal-600 hover:text-white transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a
                href={socials.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="w-9 h-9 flex items-center justify-center rounded-full bg-white text-gray-700 hover:bg-teal-600 hover:text-white transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.148 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
